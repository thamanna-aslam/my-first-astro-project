---
const my_object={
	name:"John",
	age:30,
	email:"john@example.com"};
const my_arr=["Nicolas","John","Jane","Jim"];
import people from "../data/sample.json";
const req = await fetch("https://jsonplaceholder.typicode.com/todos/1");
const data = await req.json();
console.log(data);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>My First Astro Site</title>
  </head>

  <body>
    <h1>Hello World</h1>
	<p>{my_object.name}</p>
	<p>{my_object.age}</p>
	<p>{my_object.email}</p>
	<p>{my_arr.map((name) =>
	 <p>{name}</p>)}
	 {
		people.map((person) =>
		<p>{person.name}</p>
		<p>{person.age}</p>
		<p>{person.email}</p>
		<p>{person.occupation}</p>
		)
	 }
  </body>
</html>